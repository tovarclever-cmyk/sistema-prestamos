<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../partials/sidebar') %>

            <div class="col py-3">
                <div class="container">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2>💎 Empeños y Garantías</h2>
                        <a href="/empenos/crear" class="btn btn-warning text-dark fw-bold">
                            <i class="bi bi-box-seam"></i> Nuevo Ingreso
                        </a>
                    </div>

                    <% if(mensajeExito && mensajeExito.length > 0) { %>
                        <div class="d-none" id="flashMessageSuccess"><%= mensajeExito %></div>
                    <% } %>

                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        <% if (empenos.length > 0) { %>
                            <% empenos.forEach(e => { %>
                                <div class="col">
                                    <div class="card card-box h-100 border-0 shadow-sm">
                                        <div style="height: 200px; overflow: hidden;" class="bg-light d-flex align-items-center justify-content-center">
                                            <% if(e.imagen) { %>
                                                <img src="/uploads/<%= e.imagen %>" class="card-img-top" style="height: 100%; width: 100%; object-fit: cover;">
                                            <% } else { %>
                                                <i class="bi bi-camera-off fs-1 text-muted"></i>
                                                <p class="text-muted ms-2">Sin Foto</p>
                                            <% } %>
                                        </div>

                                        <div class="card-body">
                                            <div class="d-flex justify-content-between mb-2">
                                                <% if(e.estado === 'en_custodia') { %>
                                                    <span class="badge bg-primary">En Custodia</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Devuelto</span>
                                                <% } %>
                                                <small class="text-muted"><%= new Date(e.fecha_limite).toLocaleDateString() %></small>
                                            </div>

                                            <h5 class="card-title fw-bold"><%= e.nombre_articulo %></h5>
                                            <p class="card-text text-muted small text-truncate"><%= e.descripcion %></p>

                                            <div class="row mt-3 text-center">
                                                <div class="col-6 border-end">
                                                    <small class="text-muted d-block">Tasación</small>
                                                    <span class="fw-bold text-dark"><%= empresa.moneda %><%= parseFloat(e.valor_tasacion).toFixed(2) %></span>
                                                </div>
                                                <div class="col-6">
                                                    <small class="text-muted d-block">Prestado</small>
                                                    <span class="fw-bold text-primary"><%= empresa.moneda %><%= parseFloat(e.monto_prestado).toFixed(2) %></span>
                                                </div>
                                            </div>

                                            <div class="mt-3 pt-3 border-top">
                                                <small class="text-muted"><i class="bi bi-person"></i> Cliente:</small>
                                                <div class="fw-bold"><%= e.nombre %> <%= e.apellido %></div>
                                                <% if(e.estado === 'en_custodia') { %>
                                                    <small class="text-danger">Vence: <%= new Date(e.fecha_limite).toLocaleDateString() %></small>
                                                <% } %>
                                            </div>
                                        </div>

                                        <% if(e.estado === 'en_custodia') { %>
                                            <div class="card-footer bg-white border-0 pb-3">
                                                <a href="/empenos/liberar/<%= e.id %>" class="btn btn-outline-success w-100" onclick="return confirm('¿Confirmar devolución del artículo al cliente?');">
                                                    <i class="bi bi-arrow-return-left"></i> Devolver al Cliente
                                                </a>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-box fs-1 text-muted"></i>
                                <p class="text-muted">No hay artículos en garantía registrados.</p>
                            </div>
                        <% } %>
                    </div>

                </div>
            </div>
        </div>
    </div>
<%- include('../partials/footer') %>