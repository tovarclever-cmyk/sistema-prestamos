<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../partials/sidebar') %>

            <div class="col py-3">
                <div class="container">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2>🐖 Cuentas de Ahorro</h2>
                        <a href="/ahorros/aperturar" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Aperturar Cuenta
                        </a>
                    </div>

                    <% if(mensajeExito && mensajeExito.length > 0) { %>
                        <div class="d-none" id="flashMessageSuccess"><%= mensajeExito %></div>
                    <% } %>

                    <div class="card card-box p-3">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID Cuenta</th>
                                        <th>Titular</th>
                                        <th>DNI</th>
                                        <th class="text-end">Saldo Disponible</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (cuentas.length > 0) { %>
                                        <% cuentas.forEach(c => { %>
                                            <tr>
                                                <td><span class="badge bg-secondary">#<%= c.id %></span></td>
                                                <td class="fw-bold"><%= c.nombre %> <%= c.apellido %></td>
                                                <td><%= c.dni %></td>
                                                <td class="text-end fw-bold text-success fs-5">
                                                    <%= empresa.moneda %> <%= parseFloat(c.saldo_actual).toFixed(2) %>
                                                </td>
                                                <td>
                                                    <a href="/ahorros/ver/<%= c.id %>" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-arrow-left-right"></i> Operaciones
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="text-center py-5">No hay cuentas de ahorro activas.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
<%- include('../partials/footer') %>