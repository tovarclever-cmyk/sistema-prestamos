<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión - Sistema de Préstamos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #e9ecef;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            width: 100%;
            max-width: 400px;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .card-header {
            background: #343a40;
            color: white;
            text-align: center;
            padding: 20px;
        }
    </style>
</head>
<body>

    <div class="card login-card border-0">
        <div class="card-header">
            <h4>Sistema de Préstamos</h4>
            <small>Acceso Seguro</small>
        </div>
        <div class="card-body p-4 bg-white">
            
            <% if(mensajeError && mensajeError.length > 0) { %>
                <div class="alert alert-danger text-center"><%= mensajeError %></div>
            <% } %>

            <form action="/auth/login" method="POST">
                <div class="mb-3">
                    <label class="form-label text-muted">Correo Electrónico</label>
                    <input type="email" name="email" class="form-control form-control-lg" placeholder="admin@sistema.com" required>
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted">Contraseña</label>
                    <input type="password" name="password" class="form-control form-control-lg" placeholder="******" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Ingresar</button>
                </div>
            </form>
        </div>
        <div class="card-footer text-center bg-light py-3">
            <small class="text-muted">&copy; 2025 Sistema Profesional</small>
        </div>
    </div>

</body>
</html>